          "format": "table",
          "rawQuery": true,
          "rawSql": "with cte1 as (\n  select distinct dt\n  from hh_ds order by 1),\ncte2 as (\n  SELECT hh_ds.dt, COUNT(*) AS \"error count\" \n  FROM hh_ds \n  left join vacancy_descriptions vd on hh_ds.vac_id = vd.vac_id\n  WHERE vd.vac_id IS NULL \n  GROUP BY dt \n)\nselect cte1.*,coalesce(cte2.\"error count\",0)\nfrom cte1\nleft join cte2 on cte1.dt = cte2.dt\n\n",
          "refId": "A",
          "sql": {
